# ============================================
# Mustang 어투 변환기 - OpenAI Compatible API 설정
# ============================================
# .env.local 파일로 복사한 뒤 실제 값을 채워주세요.
#
# 지원하는 Provider 예시:
# - OpenAI 공식: https://api.openai.com/v1   (gpt-4o-mini, gpt-4o 등)
# - Groq (빠르고 저렴): https://api.groq.com/openai/v1   (llama-3.1-70b 등)
# - OpenRouter: https://openrouter.ai/api/v1
# - Ollama (로컬): http://localhost:11434/v1   (gemma2, llama3.1 등)
# ============================================

OPENAI_API_KEY=sk-proj-여기에_당신의_API_키를_넣으세요

OPENAI_BASE_URL=https://api.openai.com/v1

# 추천 모델 (가성비 좋음)
OPENAI_MODEL=gpt-4o-mini

# Groq 사용 시 예시
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
